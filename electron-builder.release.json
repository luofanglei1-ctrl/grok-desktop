  "icon": "assets/icon.png",
  "linux": {
    "target": [
      {
        "target": "AppImage",
        "arch": [
          "x64"
        ]
      },
      {
        "target": "deb",
        "arch": [
          "x64"
        ]
      }
    ],
    "category": "Development",
    "icon": "assets/icon.png",
    "executableName": "grok-desktop",
    "syncDesktopName": true,
    "synopsis": "Grok Build desktop for Linux",
    "description": "Standalone Grok Build desktop shell: multi-session, plan panel, zh/en UI, official grok CLI (ACP).",
    "desktop": {
      "entry": {
        "Name": "Grok Desktop",
        "Name[zh_CN]": "Grok 桌面版",
        "Comment": "Grok Build standalone desktop",
        "Comment[zh_CN]": "Grok Build 独立桌面端",
        "Categories": "Development;Utility;",
        "StartupWMClass": "grok-desktop"
      }
    }
  },
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": [
          "x64"
        ]
      },
      {
        "target": "portable",
        "arch": [
          "x64"
        ]
      }
    ],
    "icon": "assets/icon.ico",
    "executableName": "Grok Desktop"
  },
  "nsis": {
    "artifactName": "Grok-Desktop-${version}-Windows-Setup-x64.exe",
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": "always",
    "createStartMenuShortcut": true,
    "shortcutName": "Grok Desktop",
    "installerIcon": "assets/icon.ico",
    "uninstallerIcon": "assets/icon.ico",
    "installerHeaderIcon": "assets/icon.ico"
  },
  "portable": {
    "artifactName": "Grok-Desktop-${version}-Windows-Portable-x64.exe"
  },
  "deb": {
    "packageCategory": "devel",
    "priority": "optional",
    "depends": [
      "libgtk-3-0",
      "libnotify4",
      "libnss3",
      "libxss1",
      "libxtst6",
      "xdg-utils",
      "libatspi2.0-0",
      "libuuid1"
    ]
  },
  "appImage": {
    "artifactName": "Grok-Desktop-${version}-x86_64.AppImage"
